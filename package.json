{
  "name": "youtube-music-desktop-app",
  "productName": "YTM Desktop",
  "version": "3.0.9",
  "description": "A modern, high-performance YouTube Music desktop client",
  "main": ".vite/main/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish:dry": "electron-forge publish --dry-run",
    "publish:fromdry": "electron-forge publish --from-dry-run",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx,.vue .",
    "lint:fix": "eslint --ext .ts,.tsx,.vue .",
    "typecheck": "vue-tsc --noEmit",
    "prettier": "prettier --check \"src/**/*.{ts,tsx,vue,js,css}\" \"config/**/*.ts\" \"*.{ts,json}\"",
    "prettier:fix": "prettier --write \"src/**/*.{ts,tsx,vue,js,css}\" \"config/**/*.ts\" \"*.{ts,json}\"",
    "check": "yarn typecheck && yarn lint && yarn prettier",
    "release:check": "yarn check && yarn package",
    "postinstall": "husky install"
  },
  "keywords": [
    "youtube-music",
    "desktop",
    "electron",
    "music",
    "stream-deck"
  ],
  "author": {
    "name": "AaranCloud",
    "email": "10285730+Lostepic@users.noreply.github.com"
  },
  "repository": "github:Lostepic/ytmdesktop",
  "bugs": "https://github.com/Lostepic/ytmdesktop/issues",
  "homepage": "https://github.com/Lostepic/ytmdesktop#readme",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@electron-forge/cli": "~7.11.1",
    "@electron-forge/maker-deb": "~7.11.1",
    "@electron-forge/maker-rpm": "~7.11.1",
    "@electron-forge/maker-squirrel": "~7.11.1",
    "@electron-forge/maker-zip": "~7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "~7.11.1",
    "@electron-forge/plugin-fuses": "~7.11.1",
    "@electron-forge/plugin-vite": "~7.11.1",
    "@electron-forge/publisher-github": "~7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.19.11",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "40.8.5",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "3.9.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "6.4.3",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/error": "^4.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/type-provider-typebox": "^5.2.0",
    "@sinclair/typebox": "^0.34.48",
    "conf": "^15.1.0",
    "electron-log": "5.4.4",
    "electron-squirrel-startup": "^1.0.1",
    "fastify": "5.10.0",
    "material-symbols": "^0.45.8",
    "socket.io": "^4.8.3",
    "vue": "^3.5.28"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "prettier --write",
      "eslint --cache --fix"
    ]
  },
  "packageManager": "yarn@4.5.1"
}
